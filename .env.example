# Application
APP_NAME="Agentic Loan Underwriter"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development
API_V1_PREFIX="/api/v1"

# Server
HOST=0.0.0.0
PORT=8000

# Database (will be configured later)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/underwriter

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# LiteLLM (will run on localhost:4000)
LITELLM_ENDPOINT=http://localhost:4000

# LangSmith (optional, for tracing)
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=agentic-loan-underwriter